#include <stdio.h>

// Function declaration
void toh(int n, char from, char to, char aux) {
    if (n == 1) {
        printf("\nMove disk %d from %c to %c", n, from, to);
        return;
    }
    toh(n - 1, from, aux, to);
    printf("\nMove disk %d from %c to %c", n, from, to);
    toh(n - 1, aux, to, from);
}

int main() {
    int n;
    printf("Enter the number of disks: ");
    scanf("%d", &n);
    toh(n, 'A', 'C', 'B'); // A = source, C = destination, B = auxiliary
    return 0;
}
