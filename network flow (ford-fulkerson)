#include <stdio.h>
#include <limits.h>
#include <string.h>

#define V 10

int min(int a, int b) {
    return (a < b) ? a : b;
}

// BFS to find augmenting path
int bfs(int rGraph[V][V], int s, int t, int parent[], int n) {
    int visited[V] = {0};
    int queue[V], front = 0, rear = 0;

    queue[rear++] = s;
    visited[s] = 1;
    parent[s] = -1;

    while (front < rear) {
        int u = queue[front++];

        for (int v = 0; v < n; v++) {
            if (!visited[v] && rGraph[u][v] > 0) {
                queue[rear++] = v;
                parent[v] = u;
                visited[v] = 1;
            }
        }
    }

    return visited[t];
}

int maxFlow(int graph[V][V], int n, int s, int t) {
    int rGraph[V][V], parent[V];
    int i, j;

    // Copy graph to residual graph
    for (i = 0; i < n; i++)
        for (j = 0; j < n; j++)
            rGraph[i][j] = graph[i][j];

    int max_flow = 0;

    while (bfs(rGraph, s, t, parent, n)) {
        int path_flow = INT_MAX;

        // Find minimum capacity in path
        for (j = t; j != s; j = parent[j]) {
            i = parent[j];
            path_flow = min(path_flow, rGraph[i][j]);
        }

        // Update residual graph
        for (j = t; j != s; j = parent[j]) {
            i = parent[j];
            rGraph[i][j] -= path_flow;
            rGraph[j][i] += path_flow;
        }

        max_flow += path_flow;
    }

    return max_flow;
}

int main() {
    int n, s, t, graph[V][V];

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter capacity matrix:\n");
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            scanf("%d", &graph[i][j]);

    printf("Enter source and sink: ");
    scanf("%d %d", &s, &t);

    printf("Maximum flow: %d\n", maxFlow(graph, n, s, t));

    return 0;
}
